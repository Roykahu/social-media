# ============================================
# @roy_automates — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- Existing API Keys ---
APIFY_API_TOKEN=                  # Apify Instagram scraper
GEMINI_API_KEY=                   # Google Gemini 2.0 Flash (video analysis)
ANTHROPIC_API_KEY=                # Claude Sonnet (concept generation)

# --- Obsidian Sync ---
OBSIDIAN_VAULT_PATH=              # Absolute path to Obsidian vault folder

# --- Google AI Studio (Thumbnail Generation) ---
GOOGLE_AI_STUDIO_API_KEY=         # For Nano Banana / Gemini image generation

# --- Kling (DEFERRED — uncomment when ready) ---
# KLING_API_KEY=                  # From klingai.com developer portal
# KLING_BASE_URL=https://api.klingai.com

# --- Training CTA Defaults ---
# These can also be set per-config in the Configs page UI.
TRAINING_CTA_TEXT=                # e.g. "Book a Claude training for your team"
TRAINING_WEBSITE_URL=             # Your website URL
TRAINING_BOOKING_LINK=            # Direct booking/inquiry form URL
TRAINING_CURRENT_OFFER=           # e.g. "Claude Cowork Masterclass — April 2026"
TRAINING_URGENCY_LINE=            # e.g. "Only 3 corporate spots left this month"
